---
// Timeline section for JUSTIN.
---

<section id="timeline" class="py-32 bg-[#050505]" data-ps="src/components/home/Timeline.astro:1">
  <div class="max-w-7xl mx-auto px-6" data-ps="src/components/home/Timeline.astro:2">
    <div class="mb-20 text-center reveal-v2" data-ps="src/components/home/Timeline.astro:3">
      <span class="overline-text mb-4 inline-block" data-ps="src/components/home/Timeline.astro:4">THE TRAJECTORY</span>
      <h2 class="text-5xl font-extrabold text-white tracking-tighter" data-ps="src/components/home/Timeline.astro:5">Career Evolution</h2>
    </div>

    <div class="relative" data-ps="src/components/home/Timeline.astro:6">
      <!-- Vertical Line -->
      <div class="absolute left-1/2 -translate-x-1/2 h-full w-[1px] bg-red-600/30 hidden md:block" data-ps="src/components/home/Timeline.astro:7"></div>

      <div class="space-y-24" data-ps="src/components/home/Timeline.astro:8">
        <!-- Item 1 -->
        <div class="relative grid md:grid-cols-2 gap-8 items-center reveal-v2" data-ps="src/components/home/Timeline.astro:9">
          <div class="md:text-right md:pr-12" data-ps="src/components/home/Timeline.astro:10">
            <span class="text-red-600 font-bold text-xl block mb-2" data-ps="src/components/home/Timeline.astro:11">2010–2015</span>
            <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Timeline.astro:12">Ohio State & Casino Operations</h3>
            <p class="text-neutral-400" data-ps="src/components/home/Timeline.astro:13">Built the operational foundation managing high-volume cash flow and elite customer experiences at The Ohio State University and in the casino industry.</p>
          </div>
          <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-red-600 shadow-[0_0_15px_rgba(220,38,38,0.5)] z-10" data-ps="src/components/home/Timeline.astro:14"></div>
          <div class="md:pl-12" data-ps="src/components/home/Timeline.astro:15"></div>
        </div>

        <!-- Item 2 -->
        <div class="relative grid md:grid-cols-2 gap-8 items-center reveal-v2 reveal-delay-1" data-ps="src/components/home/Timeline.astro:16">
          <div class="md:text-right md:pr-12 order-2 md:order-1" data-ps="src/components/home/Timeline.astro:17"></div>
          <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-red-600 shadow-[0_0_15px_rgba(220,38,38,0.5)] z-10" data-ps="src/components/home/Timeline.astro:18"></div>
          <div class="md:pl-12 order-1 md:order-2" data-ps="src/components/home/Timeline.astro:19">
            <span class="text-red-600 font-bold text-xl block mb-2" data-ps="src/components/home/Timeline.astro:20">2016–2017</span>
            <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Timeline.astro:21">NetJets Elite Client Management</h3>
            <p class="text-neutral-400" data-ps="src/components/home/Timeline.astro:22">Coordinated private aviation for executives and U.S. Secret Service, mastering high-stakes service and precision logistics.</p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="relative grid md:grid-cols-2 gap-8 items-center reveal-v2 reveal-delay-2" data-ps="src/components/home/Timeline.astro:23">
          <div class="md:text-right md:pr-12" data-ps="src/components/home/Timeline.astro:24">
            <span class="text-red-600 font-bold text-xl block mb-2" data-ps="src/components/home/Timeline.astro:25">2020–2021</span>
            <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Timeline.astro:26">Real Estate Pivot</h3>
            <p class="text-neutral-400" data-ps="src/components/home/Timeline.astro:27">Entered the Columbus new construction market with systems-driven precision and a relentless 'go-giver' networking philosophy.</p>
          </div>
          <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-red-600 shadow-[0_0_15px_rgba(220,38,38,0.5)] z-10" data-ps="src/components/home/Timeline.astro:28"></div>
          <div class="md:pl-12" data-ps="src/components/home/Timeline.astro:29"></div>
        </div>

        <!-- Item 4 -->
        <div class="relative grid md:grid-cols-2 gap-8 items-center reveal-v2 reveal-delay-3" data-ps="src/components/home/Timeline.astro:30">
          <div class="md:text-right md:pr-12 order-2 md:order-1" data-ps="src/components/home/Timeline.astro:31"></div>
          <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-red-600 shadow-[0_0_15px_rgba(220,38,38,0.5)] z-10" data-ps="src/components/home/Timeline.astro:32"></div>
          <div class="md:pl-12 order-1 md:order-2" data-ps="src/components/home/Timeline.astro:33">
            <span class="text-red-600 font-bold text-xl block mb-2" data-ps="src/components/home/Timeline.astro:34">2021–Present</span>
            <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Timeline.astro:35">Top 1% National Status</h3>
            <p class="text-neutral-400" data-ps="src/components/home/Timeline.astro:36">Achieved $100M+ in lifetime volume, leveraging AI and social media to scale to 8-figure operations globally.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
