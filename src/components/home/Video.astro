---
// Video section for JUSTIN.
---

<section id="video" class="py-24 bg-[#050505]" data-ps="src/components/home/Video.astro:1">
  <div class="max-w-6xl mx-auto px-6" data-ps="src/components/home/Video.astro:2">
    <div class="relative aspect-video rounded-2xl overflow-hidden border border-red-600/30 group cursor-pointer reveal-v2" data-ps="src/components/home/Video.astro:3">
      <img 
        crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1772363899381-45233513f38f?auto=format&w=1200&q=80" 
        alt="Video placeholder background" 
        class="w-full h-full object-cover brightness-50 transition-transform duration-700 group-hover:scale-105"
       data-ps="src/components/home/Video.astro:4" />
      
      <div class="absolute inset-0 flex items-center justify-center" data-ps="src/components/home/Video.astro:5">
        <div class="w-20 h-20 bg-red-600 rounded-full flex items-center justify-center shadow-2xl transition-all duration-300 group-hover:scale-110 group-hover:bg-red-500" data-ps="src/components/home/Video.astro:6">
          <svg class="w-8 h-8 text-white fill-current ml-1" viewBox="0 0 24 24" data-ps="src/components/home/Video.astro:7">
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
      </div>
      
      <div class="absolute bottom-8 left-8" data-ps="src/components/home/Video.astro:8">
        <span class="overline-text text-white/70" data-ps="src/components/home/Video.astro:9">WATCH THE DISRUPTION</span>
      </div>
    </div>
  </div>
</section>
