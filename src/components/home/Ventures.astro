---
// Ventures section for JUSTIN.
---

<section id="ventures" class="py-32 bg-[#050505]" data-ps="src/components/home/Ventures.astro:1">
  <div class="max-w-7xl mx-auto px-6" data-ps="src/components/home/Ventures.astro:2">
    <div class="mb-16 text-center reveal-v2" data-ps="src/components/home/Ventures.astro:3">
      <span class="overline-text mb-4 inline-block" data-ps="src/components/home/Ventures.astro:4">THE PORTFOLIO</span>
      <h2 class="text-5xl font-extrabold text-white tracking-tighter" data-ps="src/components/home/Ventures.astro:5">Venture Ecosystem</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/Ventures.astro:6">
      <!-- Card 1 -->
      <div class="group bg-white/5 border border-white/10 rounded-2xl p-10 transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 reveal-v2" data-ps="src/components/home/Ventures.astro:7">
        <div class="flex justify-between items-start mb-12" data-ps="src/components/home/Ventures.astro:8">
          <div class="w-12 h-12 bg-red-600 rounded flex items-center justify-center" data-ps="src/components/home/Ventures.astro:9">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-ps="src/components/home/Ventures.astro:10">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <span class="text-xs font-mono text-neutral-500 tracking-widest" data-ps="src/components/home/Ventures.astro:11">REAL ESTATE</span>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Ventures.astro:12">D.R. Horton</h3>
        <p class="text-neutral-400" data-ps="src/components/home/Ventures.astro:13">Top 1% national new home sales representative with $100M+ in volume, dominating the construction market.</p>
      </div>

      <!-- Card 2 -->
      <div class="group bg-white/5 border border-white/10 rounded-2xl p-10 transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 reveal-v2 reveal-delay-1" data-ps="src/components/home/Ventures.astro:14">
        <div class="flex justify-between items-start mb-12" data-ps="src/components/home/Ventures.astro:15">
          <div class="w-12 h-12 bg-red-600 rounded flex items-center justify-center" data-ps="src/components/home/Ventures.astro:16">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-ps="src/components/home/Ventures.astro:17">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="text-xs font-mono text-neutral-500 tracking-widest" data-ps="src/components/home/Ventures.astro:18">CONSULTING</span>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Ventures.astro:19">Phillips Consults LLC</h3>
        <p class="text-neutral-400" data-ps="src/components/home/Ventures.astro:20">Advising on compensation structures and securing top-performing sales talent for elite organizations.</p>
      </div>

      <!-- Card 3 -->
      <div class="group bg-white/5 border border-white/10 rounded-2xl p-10 transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 reveal-v2 reveal-delay-2" data-ps="src/components/home/Ventures.astro:21">
        <div class="flex justify-between items-start mb-12" data-ps="src/components/home/Ventures.astro:22">
          <div class="w-12 h-12 bg-red-600 rounded flex items-center justify-center" data-ps="src/components/home/Ventures.astro:23">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-ps="src/components/home/Ventures.astro:24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <span class="text-xs font-mono text-neutral-500 tracking-widest" data-ps="src/components/home/Ventures.astro:25">EVENTS</span>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Ventures.astro:26">Founder of Rebel Conference</h3>
        <p class="text-neutral-400" data-ps="src/components/home/Ventures.astro:27">Organizing Columbus's premier event for real estate disruption and high-performance networking.</p>
      </div>

      <!-- Card 4 -->
      <div class="group bg-white/5 border border-white/10 rounded-2xl p-10 transition-all duration-300 hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 reveal-v2 reveal-delay-3" data-ps="src/components/home/Ventures.astro:28">
        <div class="flex justify-between items-start mb-12" data-ps="src/components/home/Ventures.astro:29">
          <div class="w-12 h-12 bg-red-600 rounded flex items-center justify-center" data-ps="src/components/home/Ventures.astro:30">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-ps="src/components/home/Ventures.astro:31">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <span class="text-xs font-mono text-neutral-500 tracking-widest" data-ps="src/components/home/Ventures.astro:32">LEADERSHIP</span>
        </div>
        <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/components/home/Ventures.astro:33">Columbus REALTORS® YPN</h3>
        <p class="text-neutral-400" data-ps="src/components/home/Ventures.astro:34">Co-Chair leading the Young Professionals Network, shaping the culture of the local real estate industry.</p>
      </div>
    </div>
  </div>
</section>
